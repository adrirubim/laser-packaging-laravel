{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "laser-packaging-laravel",
    "version": "1.0.0",
    "description": "Enterprise-grade backoffice and production portal built with Laravel + Inertia (React) + Vite.",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/adrirubim/laser-packaging-laravel.git"
    },
    "private": true,
    "type": "module",
    "imports": {
        "#app/*": "./resources/js/*"
    },
    "scripts": {
        "postinstall": "node scripts/normalize-patches.cjs && (patch-package || true) && node scripts/fix-radix-after-patch.cjs && node -e \"try{require('fs').rmSync('node_modules/.vite',{recursive:!0,force:!0})}catch(e){}\"",
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "concurrently \"php artisan serve --host=0.0.0.0 --port=8000\" \"vite\"",
        "dev:vite": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "lint:scoped": "eslint --fix",
        "types": "tsc --noEmit",
        "test": "npm exec -- vitest"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.4",
        "@eslint/js": "^10.0.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@types/node": "^25.5.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^29.0.2",
        "patch-package": "^8.0.1",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.1.3"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.10",
        "@inertiajs/react": "^3.0.3",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tailwindcss/vite": "^4.2.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.2.1",
        "globals": "^17.4.0",
        "input-otp": "^1.4.2",
        "laravel-vite-plugin": "^3.0.1",
        "lucide-react": "^1.7.0",
        "primeicons": "^7.0.0",
        "primereact": "^10.9.7",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-is": "^19.2.4",
        "recharts": "^3.8.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.6"
    },
    "overrides": {
        "picomatch": "4.0.4",
        "minimatch": "10.2.4"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.60.1",
        "@rollup/rollup-win32-x64-msvc": "^4.60.1",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
        "lightningcss-linux-x64-gnu": "^1.32.0",
        "lightningcss-win32-x64-msvc": "1.32.0"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
